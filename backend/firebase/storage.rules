rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return signedIn() && userDoc().status == "active";
    }

    function isAdmin() {
      return isActive() && userDoc().role == "admin";
    }

    function sameOrg(orgId) {
      return isActive() && userDoc().orgId == orgId;
    }

    function pdfUpload(fileName) {
      return request.resource != null &&
        (
          request.resource.contentType == "application/pdf" ||
          request.resource.contentType == "application/octet-stream" ||
          fileName.matches(".*\\.[pP][dD][fF]$")
        ) &&
        request.resource.size <= 20 * 1024 * 1024;
    }

    function imageUpload(fileName) {
      return request.resource != null &&
        (
          request.resource.contentType.matches("image/.*") ||
          fileName.matches(".*\\.[jJ][pP][gG]$") ||
          fileName.matches(".*\\.[jJ][pP][eE][gG]$") ||
          fileName.matches(".*\\.[pP][nN][gG]$") ||
          fileName.matches(".*\\.[wW][eE][bB][pP]$") ||
          fileName.matches(".*\\.[hH][eE][iI][cC]$")
        ) &&
        request.resource.size <= 5 * 1024 * 1024;
    }

    match /organisations/{orgId}/library/{documentId}/{fileName} {
      allow read: if sameOrg(orgId);
      allow write: if isAdmin() && sameOrg(orgId) && pdfUpload(fileName);
    }

    match /organisations/{orgId}/profiles/{userId}/{fileName} {
      allow read: if sameOrg(orgId);
      allow write: if signedIn() &&
        request.auth.uid == userId &&
        sameOrg(orgId) &&
        imageUpload(fileName);
    }

    match /organisations/{orgId}/marketplace/{listingId}/{fileName} {
      allow read: if sameOrg(orgId);
      allow write: if sameOrg(orgId) && imageUpload(fileName);
    }

    match /organisations/{orgId}/voting/{imageId}/{fileName} {
      allow read: if sameOrg(orgId);
      allow write: if isAdmin() && sameOrg(orgId) && imageUpload(fileName);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
